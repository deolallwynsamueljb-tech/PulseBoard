{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/**"]
      }
    }
  ],
  "routes": [
    { "src": "/health",          "dest": "/api/index.py" },
    { "src": "/kpis(.*)",        "dest": "/api/index.py" },
    { "src": "/analytics(.*)",   "dest": "/api/index.py" },
    { "src": "/feedback(.*)",    "dest": "/api/index.py" },
    { "src": "/ai(.*)",          "dest": "/api/index.py" },
    { "src": "/sensors(.*)",     "dest": "/api/index.py" },
    { "src": "/freshness(.*)",   "dest": "/api/index.py" },
    { "src": "/market(.*)",      "dest": "/api/index.py" },
    { "src": "/waste(.*)",       "dest": "/api/index.py" },
    { "src": "/auth(.*)",        "dest": "/api/index.py" },
    { "src": "/ml(.*)",          "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)",            "dest": "/index.html" }
  ]
}
